# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored so your secret keys never get committed.

# The public base URL of the deployed app (used to build OAuth redirect URLs).
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://cscstestapp.com

# Supabase — Dashboard -> Project Settings -> API. These are public (safe in the app).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google Sign-In (Capacitor social login) — from Google Cloud Console.
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Apple Sign-In services identifier (from your Apple Developer account).
NEXT_PUBLIC_APPLE_SERVICES_ID=com.cscstestapp.web

# SECRET server keys — never prefixed NEXT_PUBLIC_, never committed.
# Anthropic powers the AI study coach; Resend sends transactional emails.
ANTHROPIC_API_KEY=
RESEND_API_KEY=
